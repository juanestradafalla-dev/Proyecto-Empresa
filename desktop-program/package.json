{
  "name": "gestion-almacen-panel",
  "version": "0.1.2",
  "description": "Panel de escritorio para gestion de almacen de Arles SAS conectado a Firestore.",
  "author": "Arles SAS",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "desktop": "npm run build && electron .",
    "dist:exe": "npm run build && electron-builder --win portable --x64 --config.directories.output=release",
    "dist:installer": "npm run build && electron-builder --win nsis --x64 --config.directories.output=release",
    "dist:portable": "npm run dist:exe",
    "store:assets": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-store-assets.ps1",
    "dist:store": "npm run store:assets && npm run build && electron-builder --config electron-builder.store.json --win appx --x64",
    "dist:msix": "npm run dist:store",
    "icon:create": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-arles-icon.ps1",
    "cert:trust": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/ensure-arles-signing-cert.ps1",
    "sign:release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/sign-release.ps1",
    "dist:trusted": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-trusted-release.ps1",
    "admin:inspect": "node admin/inspect.js",
    "admin:transform": "node admin/transformInventory.js --collection=inventario"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "exceljs": "^4.4.0",
    "firebase": "^12.7.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "firebase-admin": "^14.0.0",
    "minimist": "^1.2.8"
  },
  "build": {
    "appId": "com.arlessas.gestion.almacen",
    "productName": "Gestion Almacen Arles",
    "copyright": "Copyright (c) 2026 Arles SAS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/icon.ico",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "signtoolOptions": {
        "publisherName": "Arles SAS"
      },
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "include": "build-resources/installer/install-internal-cert.nsh"
    }
  }
}
