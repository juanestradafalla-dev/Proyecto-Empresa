rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == "juanestradafalla@gmail.com";
    }

    function userPath() {
      return /databases/$(database)/documents/usuarios/$(request.auth.uid);
    }

    function hasUserDoc() {
      return signedIn() && exists(userPath());
    }

    function userData() {
      return get(userPath()).data;
    }

    function isActiveUser() {
      return isOwner()
        || (
          hasUserDoc()
          && (
            userData().activo == true
            || userData().estado in ["activo", "Activo", "ACTIVO"]
            || userData().rol in [
              "owner", "Owner", "OWNER",
              "admin", "Admin", "ADMIN",
              "administrador", "Administrador", "ADMINISTRADOR",
              "almacenista", "Almacenista", "ALMACENISTA",
              "operador", "Operador", "OPERADOR"
            ]
          )
        );
    }

    function protectedProfileFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "rol", "role", "activo", "estado", "permisos"
      ]);
    }

    function isValidInventoryValuation(valoracionId) {
      return request.resource.data.keys().hasOnly([
          "valor_unitario",
          "modulo",
          "codigo",
          "descripcion",
          "actualizado_por",
          "actualizado_por_uid",
          "actualizado_en",
          "origen_actualizacion",
          "ultimo_movimiento_id"
        ])
        && request.resource.data.keys().hasAll([
          "valor_unitario",
          "modulo",
          "codigo",
          "descripcion",
          "actualizado_por",
          "actualizado_por_uid",
          "actualizado_en",
          "origen_actualizacion"
        ])
        && request.resource.data.valor_unitario is number
        && request.resource.data.valor_unitario >= 0
        && request.resource.data.modulo is string
        && request.resource.data.codigo is string
        && request.resource.data.descripcion is string
        && request.resource.data.actualizado_por is string
        && request.resource.data.actualizado_por_uid == request.auth.uid
        && request.resource.data.actualizado_en == request.time
        && request.resource.data.origen_actualizacion in ["manual", "entrada_stock"]
        && (
          request.resource.data.origen_actualizacion == "manual"
          || (
            request.resource.data.keys().hasAll(["ultimo_movimiento_id"])
            && request.resource.data.ultimo_movimiento_id is string
            && request.resource.data.ultimo_movimiento_id.size() > 0
            && existsAfter(
              /databases/$(database)/documents/valoraciones_entradas/$(request.resource.data.ultimo_movimiento_id)
            )
            && getAfter(
              /databases/$(database)/documents/valoraciones_entradas/$(request.resource.data.ultimo_movimiento_id)
            ).data.valoracion_id == valoracionId
            && getAfter(
              /databases/$(database)/documents/valoraciones_entradas/$(request.resource.data.ultimo_movimiento_id)
            ).data.promedio_nuevo == request.resource.data.valor_unitario
            && getAfter(
              /databases/$(database)/documents/valoraciones_entradas/$(request.resource.data.ultimo_movimiento_id)
            ).data.usuario_uid == request.auth.uid
          )
        );
    }

    function isMappedInventoryValuation(valoracionId, modulo) {
      return (
          modulo == "ASEO"
          && valoracionId.matches("^productos_aseo__.+$")
        )
        || (
          (modulo == "Taller" || modulo.matches(".*[Hh]erramienta.*"))
          && valoracionId.matches("^herramientas__.+$")
        )
        || (
          modulo != "ASEO"
          && modulo != "Taller"
          && !modulo.matches(".*[Hh]erramienta.*")
          && valoracionId.matches("^existencias__.+$")
        );
    }

    function isExcludedEntryMovement(data) {
      return (
          data.keys().hasAny(["tipoMovimiento"])
          && data.tipoMovimiento is string
          && data.tipoMovimiento.matches(".*([Ss]alida|[Dd]evoluci[oó]n|[Rr]etorno|[Tt]raslado).*")
        )
        || (
          data.keys().hasAny(["tipo"])
          && data.tipo is string
          && data.tipo.matches(".*([Ss]alida|[Dd]evoluci[oó]n|[Rr]etorno|[Tt]raslado).*")
        )
        || (
          data.keys().hasAny(["clase"])
          && data.clase is string
          && data.clase.matches(".*([Ss]alida|[Dd]evoluci[oó]n|[Rr]etorno|[Tt]raslado).*")
        )
        || (data.keys().hasAny(["es_devolucion"]) && data.es_devolucion == true)
        || (data.keys().hasAny(["es_retorno"]) && data.es_retorno == true)
        || (data.keys().hasAny(["es_traslado"]) && data.es_traslado == true)
        || (
          data.keys().hasAny(["movimiento_entre_ubicaciones"])
          && data.movimiento_entre_ubicaciones == true
        )
        || (
          data.keys().hasAll(["ubicacion_origen", "ubicacion_destino"])
          && data.ubicacion_origen is string
          && data.ubicacion_origen.size() > 0
          && data.ubicacion_destino is string
          && data.ubicacion_destino.size() > 0
        );
    }

    function isValidEntryValuation(movimientoId) {
      let movementPath = /databases/$(database)/documents/movimientos/$(movimientoId);
      let movement = get(movementPath);
      let inventoryPath = /databases/$(database)/documents/valoraciones_inventario/$(request.resource.data.valoracion_id);
      let inventoryBefore = get(inventoryPath);
      let inventoryAfter = getAfter(inventoryPath);
      let expectedAverage = request.resource.data.stock_anterior == 0
        ? request.resource.data.valor_unitario_entrada
        : (
          (request.resource.data.stock_anterior * request.resource.data.promedio_anterior)
          + (request.resource.data.cantidad * request.resource.data.valor_unitario_entrada)
        ) / request.resource.data.stock_nuevo;

      return request.resource.data.keys().hasOnly([
          "movimiento_id",
          "producto_id",
          "valoracion_id",
          "modulo",
          "codigo",
          "producto",
          "referencia",
          "cantidad",
          "stock_anterior",
          "stock_nuevo",
          "valor_unitario_entrada",
          "promedio_anterior",
          "promedio_nuevo",
          "usuario",
          "usuario_uid",
          "movimiento_creado_en",
          "valorado_en"
        ])
        && request.resource.data.keys().hasAll([
          "movimiento_id",
          "producto_id",
          "valoracion_id",
          "modulo",
          "codigo",
          "producto",
          "referencia",
          "cantidad",
          "stock_anterior",
          "stock_nuevo",
          "valor_unitario_entrada",
          "promedio_anterior",
          "promedio_nuevo",
          "usuario",
          "usuario_uid",
          "movimiento_creado_en",
          "valorado_en"
        ])
        && request.resource.data.movimiento_id == movimientoId
        && request.resource.data.producto_id is string
        && request.resource.data.producto_id.size() > 0
        && request.resource.data.valoracion_id is string
        && request.resource.data.modulo is string
        && request.resource.data.modulo.size() > 0
        && request.resource.data.codigo is string
        && request.resource.data.producto is string
        && request.resource.data.producto.size() > 0
        && request.resource.data.referencia is string
        && request.resource.data.cantidad is number
        && request.resource.data.cantidad > 0
        && request.resource.data.stock_anterior is number
        && request.resource.data.stock_anterior >= 0
        && request.resource.data.stock_nuevo is number
        && request.resource.data.stock_nuevo > 0
        && request.resource.data.valor_unitario_entrada is number
        && request.resource.data.valor_unitario_entrada >= 0
        && request.resource.data.promedio_anterior is number
        && request.resource.data.promedio_anterior >= 0
        && request.resource.data.promedio_nuevo is number
        && request.resource.data.promedio_nuevo >= 0
        && request.resource.data.usuario is string
        && request.resource.data.usuario.size() > 0
        && request.resource.data.usuario_uid == request.auth.uid
        && request.resource.data.movimiento_creado_en is timestamp
        && request.resource.data.valorado_en == request.time
        && exists(movementPath)
        && movement.data.keys().hasAll([
          "clase_movimiento",
          "stock_actualizado",
          "producto_id",
          "stock_anterior",
          "stock_nuevo",
          "creado_en",
          "modulo"
        ])
        && movement.data.clase_movimiento == "entrada_stock"
        && !isExcludedEntryMovement(movement.data)
        && movement.data.stock_actualizado == true
        && movement.data.producto_id == request.resource.data.producto_id
        && movement.data.stock_anterior == request.resource.data.stock_anterior
        && movement.data.stock_nuevo == request.resource.data.stock_nuevo
        && movement.data.creado_en == request.resource.data.movimiento_creado_en
        && movement.data.modulo == request.resource.data.modulo
        && isMappedInventoryValuation(
          request.resource.data.valoracion_id,
          request.resource.data.modulo
        )
        && request.resource.data.stock_nuevo
          >= request.resource.data.stock_anterior + request.resource.data.cantidad - 0.000001
        && request.resource.data.stock_nuevo
          <= request.resource.data.stock_anterior + request.resource.data.cantidad + 0.000001
        && (
          (
            request.resource.data.stock_anterior == 0
            && request.resource.data.promedio_anterior == 0
          )
          || (
            request.resource.data.stock_anterior > 0
            && exists(inventoryPath)
            && inventoryBefore.data.valor_unitario is number
            && inventoryBefore.data.valor_unitario == request.resource.data.promedio_anterior
          )
        )
        && request.resource.data.promedio_nuevo >= expectedAverage - 0.000001
        && request.resource.data.promedio_nuevo <= expectedAverage + 0.000001
        && existsAfter(inventoryPath)
        && inventoryAfter.data.valor_unitario == request.resource.data.promedio_nuevo
        && inventoryAfter.data.actualizado_por_uid == request.auth.uid
        && inventoryAfter.data.actualizado_en == request.time
        && inventoryAfter.data.origen_actualizacion == "entrada_stock"
        && inventoryAfter.data.ultimo_movimiento_id == movimientoId;
    }

    function isValidMonthlyValuationClose(periodo) {
      return request.resource.data.keys().hasOnly([
          "periodo",
          "resumen",
          "fecha",
          "usuario",
          "usuario_uid",
          "estado",
          "intento_id",
          "verificacion"
        ])
        && periodo.matches("^[0-9]{4}-(0[1-9]|1[0-2])$")
        && request.resource.data.periodo == periodo
        && request.resource.data.resumen is map
        && request.resource.data.resumen.keys().hasOnly([
          "valor_total",
          "cantidad_productos",
          "productos_con_valor",
          "productos_sin_valor",
          "porcentaje_valorado",
          "totales_modulo"
        ])
        && request.resource.data.resumen.valor_total is number
        && request.resource.data.resumen.valor_total >= 0
        && request.resource.data.resumen.cantidad_productos is int
        && request.resource.data.resumen.cantidad_productos >= 0
        && request.resource.data.resumen.productos_con_valor is int
        && request.resource.data.resumen.productos_con_valor >= 0
        && request.resource.data.resumen.productos_sin_valor is int
        && request.resource.data.resumen.productos_sin_valor >= 0
        && request.resource.data.resumen.productos_con_valor
          + request.resource.data.resumen.productos_sin_valor
          == request.resource.data.resumen.cantidad_productos
        && request.resource.data.resumen.porcentaje_valorado is number
        && request.resource.data.resumen.porcentaje_valorado >= 0
        && request.resource.data.resumen.porcentaje_valorado <= 100
        && request.resource.data.resumen.totales_modulo is map
        && request.resource.data.fecha is timestamp
        && request.resource.data.usuario is string
        && request.resource.data.usuario.size() > 0
        && request.resource.data.usuario_uid == request.auth.uid
        && request.resource.data.estado in ["guardando", "completo", "error"]
        && request.resource.data.intento_id is string
        && request.resource.data.intento_id.size() > 0
        && request.resource.data.verificacion is map
        && request.resource.data.verificacion.keys().hasOnly([
          "cantidad_items",
          "suma_total",
          "ids_hash",
          "verificado"
        ])
        && request.resource.data.verificacion.cantidad_items is int
        && request.resource.data.verificacion.cantidad_items >= 0
        && request.resource.data.verificacion.suma_total is number
        && request.resource.data.verificacion.suma_total >= 0
        && request.resource.data.verificacion.ids_hash is string
        && request.resource.data.verificacion.verificado is bool
        && (
          (
            request.resource.data.estado == "completo"
            && request.resource.data.verificacion.verificado == true
            && request.resource.data.verificacion.cantidad_items
              == request.resource.data.resumen.cantidad_productos
            && request.resource.data.verificacion.suma_total
              >= request.resource.data.resumen.valor_total
                - (request.resource.data.resumen.valor_total + 1) * 0.000001
            && request.resource.data.verificacion.suma_total
              <= request.resource.data.resumen.valor_total
                + (request.resource.data.resumen.valor_total + 1) * 0.000001
            && request.resource.data.verificacion.ids_hash.size() > 0
          )
          || (
            request.resource.data.estado in ["guardando", "error"]
            && request.resource.data.verificacion.verificado == false
          )
        );
    }

    function isValidMonthlyValuationItem(itemId, intentoId) {
      return request.resource.data.keys().hasOnly([
          "item_id",
          "intento_id",
          "modulo",
          "codigo",
          "referencia",
          "producto",
          "cantidad",
          "unidad",
          "valor_unitario",
          "valor_total"
        ])
        && request.resource.data.item_id == itemId
        && request.resource.data.intento_id == intentoId
        && request.resource.data.modulo is string
        && request.resource.data.modulo.size() > 0
        && request.resource.data.codigo is string
        && request.resource.data.referencia is string
        && request.resource.data.producto is string
        && request.resource.data.producto.size() > 0
        && request.resource.data.cantidad is number
        && request.resource.data.cantidad >= 0
        && request.resource.data.unidad is string
        && request.resource.data.unidad.size() > 0
        && request.resource.data.valor_unitario is number
        && request.resource.data.valor_unitario >= 0
        && request.resource.data.valor_total is number
        && request.resource.data.valor_total >= 0
        && request.resource.data.valor_total
          >= request.resource.data.cantidad * request.resource.data.valor_unitario
            - (request.resource.data.valor_total + 1) * 0.000001
        && request.resource.data.valor_total
          <= request.resource.data.cantidad * request.resource.data.valor_unitario
            + (request.resource.data.valor_total + 1) * 0.000001;
    }

    function isSharedBusinessCollection(collectionName) {
      return collectionName in [
        // GestionAndroid apps + desktop-program
        "existencias",
        "catalogo_personalizado",
        "movimientos",
        "productos_aseo",
        "productos_aseo_archivados",
        "areas_aseo",
        "areas_cop",
        "herramientas",
        "entradas",
        "vencimientos",
        "correcciones_registros",
        "memoria_ia",
        "backups",
        "sistema",

        // Mantenimiento Preventivo Maestro
        "mantenimiento_preventivo_maestro_catalogo",
        "mantenimiento_preventivo_maestro_historial",
        "mantenimiento_preventivo_maestro_reportes",
        "mantenimiento_preventivo_maestro_trabajadores",
        "mantenimiento_preventivo_maestro_auditoria",

        // Nombres legacy de mantenimiento, por si quedaron datos viejos.
        "mantenimientoPreventivo_equipos",
        "mantenimientoPreventivo_registros"
      ];
    }

    function isValidFieldReportCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "equipo_id",
          "equipo_codigo",
          "equipo_nombre",
          "fecha",
          "trabajador",
          "trabajador_uid",
          "trabajador_nombre",
          "trabajador_alias",
          "tipo_reporte",
          "descripcion",
          "fotoUrl",
          "fotoPath",
          "estado_reporte",
          "origen",
          "creado_en",
          "user_uid"
        ])
        && request.resource.data.equipo_id is string
        && request.resource.data.equipo_codigo is string
        && request.resource.data.equipo_nombre is string
        && request.resource.data.fecha is string
        && request.resource.data.trabajador is string
        && request.resource.data.trabajador_uid == request.auth.uid
        && request.resource.data.trabajador_nombre is string
        && request.resource.data.trabajador_alias is string
        && request.resource.data.tipo_reporte in ["falla", "inspeccion", "limpieza", "daño"]
        && request.resource.data.descripcion is string
        && request.resource.data.estado_reporte == "pendiente"
        && request.resource.data.origen in ["app_android_qr", "app_qr", "portal_reportador"]
        && request.resource.data.user_uid == request.auth.uid
        && request.resource.data.equipo_codigo.size() > 0
        && request.resource.data.trabajador.size() > 0
        && request.resource.data.descripcion.size() > 0
        && request.resource.data.descripcion.size() <= 4000;
    }

    function isValidWorkerProfile(workerUid) {
      return signedIn()
        && workerUid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "uid",
          "nombre",
          "alias",
          "nombre_mostrado",
          "dispositivo",
          "origen",
          "actualizado_en",
          "creado_en"
        ])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.nombre is string
        && request.resource.data.alias is string
        && request.resource.data.nombre_mostrado is string
        && request.resource.data.dispositivo is string
        && request.resource.data.origen == "app_android_reportes"
        && request.resource.data.nombre.size() > 0
        && request.resource.data.nombre.size() <= 160
        && request.resource.data.alias.size() <= 120
        && request.resource.data.nombre_mostrado.size() <= 240;
    }

    function isValidAuditCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          "evento",
          "trabajador_uid",
          "trabajador_nombre",
          "trabajador_alias",
          "trabajador",
          "origen",
          "dispositivo",
          "creado_en",
          "trabajador_anterior",
          "alias_anterior",
          "reporte_id",
          "equipo_codigo",
          "tipo_reporte",
          "fotoPath",
          "tiene_evidencia"
        ])
        && request.resource.data.evento in [
          "trabajador_registrado",
          "trabajador_actualizado",
          "reporte_creado"
        ]
        && request.resource.data.trabajador_uid == request.auth.uid
        && request.resource.data.trabajador_nombre is string
        && request.resource.data.trabajador_alias is string
        && request.resource.data.trabajador is string
        && request.resource.data.origen == "app_android_reportes"
        && request.resource.data.dispositivo is string
        && request.resource.data.trabajador_nombre.size() > 0
        && request.resource.data.trabajador_nombre.size() <= 160
        && request.resource.data.trabajador.size() <= 240;
    }

    match /conversacion_ia/{uid}/mensajes/{mensajeId} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    match /mantenimiento_preventivo_maestro_reportes/{reporteId} {
      allow create: if isValidFieldReportCreate();
      allow read, update, delete: if isActiveUser();
    }

    match /mantenimiento_preventivo_maestro_trabajadores/{workerUid} {
      allow create, update: if isValidWorkerProfile(workerUid);
      allow read: if isActiveUser() || (signedIn() && workerUid == request.auth.uid);
      allow delete: if isActiveUser();
    }

    match /mantenimiento_preventivo_maestro_auditoria/{auditId} {
      allow create: if isValidAuditCreate();
      allow read, update, delete: if isActiveUser();
    }

    match /usuarios/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email
        && !(request.resource.data.rol in ["admin", "administrador", "owner"])
        && request.resource.data.activo != true;

      allow read: if isActiveUser() || (signedIn() && request.auth.uid == uid);

      allow update: if isOwner()
        || (
          signedIn()
          && request.auth.uid == uid
          && !protectedProfileFieldsChanged()
        );

      allow delete: if isOwner();
    }

    match /valoraciones_inventario/{valoracionId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser() && isValidInventoryValuation(valoracionId);
    }

    match /valoraciones_entradas/{movimientoId} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && !exists(/databases/$(database)/documents/valoraciones_entradas/$(movimientoId))
        && isValidEntryValuation(movimientoId);
    }

    match /cierres_valoracion_inventario/{periodo} {
      allow read: if isActiveUser();
      allow create: if isActiveUser()
        && !exists(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo))
        && request.resource.data.estado == "guardando"
        && request.resource.data.fecha == request.time
        && isValidMonthlyValuationClose(periodo);
      allow update: if isActiveUser()
        && resource.data.usuario_uid == request.auth.uid
        && request.resource.data.usuario_uid == resource.data.usuario_uid
        && request.resource.data.periodo == resource.data.periodo
        && (
          (
            resource.data.estado == "guardando"
            && request.resource.data.estado == "error"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["estado"])
          )
          || (
            resource.data.estado == "guardando"
            && request.resource.data.estado == "completo"
            && request.resource.data.fecha == request.time
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              "estado",
              "fecha",
              "verificacion"
            ])
          )
          || (
            resource.data.estado == "error"
            && request.resource.data.estado == "guardando"
            && request.resource.data.fecha == request.time
          )
        )
        && isValidMonthlyValuationClose(periodo);

      match /items/{itemId} {
        allow read: if isActiveUser();
        allow create, update: if isActiveUser()
          && get(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo)).data.estado == "guardando"
          && get(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo)).data.usuario_uid == request.auth.uid
          && isValidMonthlyValuationItem(
            itemId,
            get(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo)).data.intento_id
          );
        allow delete: if isActiveUser()
          && get(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo)).data.estado == "guardando"
          && get(/databases/$(database)/documents/cierres_valoracion_inventario/$(periodo)).data.usuario_uid == request.auth.uid;
      }
    }

    match /{collectionName}/{document=**} {
      allow read, write: if isSharedBusinessCollection(collectionName) && isActiveUser();
    }
  }
}
